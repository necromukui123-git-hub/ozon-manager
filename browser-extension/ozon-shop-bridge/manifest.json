{
  "manifest_version": 3,
  "name": "Ozon Manager Shop Bridge",
  "description": "在当前 Chrome 登录态下执行 Ozon 店铺促销任务（默认静默执行）。",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://seller.ozon.ru/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Ozon Manager Bridge",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://localhost/*"
      ],
      "js": [
        "content-auth-sync.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
